# ==========================================================================
# Trader OS — .env template (committed)
# ==========================================================================
# Real values live in .env.local (gitignored). Vite auto-loads .env.local
# and overrides this template at runtime. Copy this file to .env.local and
# fill in real values for local development.
# ==========================================================================

# Supabase project URL — Lovable Cloud → Connectors → Supabase, or
# Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=your-supabase-project-url
SUPABASE_URL=your-supabase-project-url

# Supabase anon / publishable key — Project Settings → API.
# Safe for client-side use. NEVER put the service-role key here.
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Supabase project ref — the subdomain portion of VITE_SUPABASE_URL.
VITE_SUPABASE_PROJECT_ID=your-supabase-project-ref
