# ==========================================================================
# Trader OS — Environment Variables
# ==========================================================================
# Copy this file to `.env` for local development. Real values for the
# managed Lovable Cloud project are auto-injected; you only need to fill
# this in for local Supabase, staging, or self-hosted setups.
# ==========================================================================

# --- Supabase (client) -----------------------------------------------------
# Public, safe to expose to the browser.
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# --- Supabase (server) -----------------------------------------------------
# Used by SSR / server functions. Mirrors the VITE_* values.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
# SECRET — never expose to the browser. Only used by trusted server code.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Environment tag -------------------------------------------------------
# One of: development | staging | production
# Drives observability formatting and feature gating.
VITE_APP_ENV="development"

# --- Playwright E2E (optional, local + CI) --------------------------------
# Credentials for the deterministic seeded test user. Create this user in
# the target Supabase project before running E2E tests.
# E2E_EMAIL="e2e@traderos.test"
# E2E_PASSWORD="change-me-in-staging"
# E2E_BASE_URL="http://localhost:5173"
